# ==========================================
# AWS Configuration (For Rekognition & Bedrock)
# ==========================================
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1

# Optional: For specialized Hackathon Bedrock access
AWS_BEARER_TOKEN_BEDROCK=your_bearer_token_here

# ==========================================
# OpenAI / AI Gateway Configuration
# ==========================================
OPENAI_API_KEY=your_openai_or_gateway_key_here
OPENAI_BASE_URL=https://your.gateway.url/v1

# ==========================================
# Flask Backend Configuration
# ==========================================
FLASK_PORT=5000
FLASK_DEBUG=True

# ==========================================
# ML Model Settings
# ==========================================
# Ensure this file is placed in the same folder as server.py
MODEL_NAME=Emotion_Voice_Detection_Model.h5